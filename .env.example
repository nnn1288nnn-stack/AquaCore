# 澎湖數位老船長 - 環境配置範本
# 複製此文件為 .env 並填入實際配置

# ========================================
# 數據庫配置
# ========================================
DB_ROOT_PASSWORD=penghu2024aqua!
DB_NAME=aquaculture_db
DB_USER=appuser
DB_PASSWORD=apppass123
DB_HOST=mariadb
DB_PORT=3306

# ========================================
# Golang API 配置
# ========================================
GO_PORT=8080
GO_ENV=development
GO_LOG_LEVEL=info

# ========================================
# Python AI 配置
# ========================================
PYTHON_PORT=8000
PYTHON_ENV=development
PYTHON_LOG_LEVEL=info

# ========================================
# API 連接
# ========================================
GOLANG_API_URL=http://golang-api:8080

# ========================================
# OpenAI 配置
# ========================================
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4-turbo
OPENAI_ORG_ID=

# ========================================
# Gemini 配置
# ========================================
GEMINI_API_KEY=your-gemini-key-here

# ========================================
# LINE LIFF 配置
# ========================================
LINE_CHANNEL_ID=your-line-channel-id
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_USER_ID=your-line-user-id

# ========================================
# Nginx 配置
# ========================================
NGINX_PORT=80
NGINX_SSL_PORT=443

# ========================================
# 日誌配置
# ========================================
LOG_LEVEL=info
LOG_FORMAT=json

# ========================================
# 生產環境設置 (若使用)
# ========================================
# 取消下面的註釋以啟用生產模式

# GO_ENV=production
# PYTHON_ENV=production
# LOG_LEVEL=warn
